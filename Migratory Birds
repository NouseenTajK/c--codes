#include <stdio.h>

int migratoryBirds(int arr[], int n) {
    int freq[6] = {0};  // Bird types are 1 to 5

    for (int i = 0; i < n; i++) {
        freq[arr[i]]++;
    }

    int maxFreq = 0;
    int birdType = 0;

    for (int i = 1; i <= 5; i++) {
        if (freq[i] > maxFreq) {
            maxFreq = freq[i];
            birdType = i;
        }
    }

    return birdType;
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("%d\n", migratoryBirds(arr, n));

    return 0;
}
