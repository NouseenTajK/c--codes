#include <stdio.h>

int birthdayCakeCandles(int candles[], int n) {
    int max = candles[0];
    int count = 0;

    // Find maximum height
    for (int i = 1; i < n; i++) {
        if (candles[i] > max) {
            max = candles[i];
        }
    }

    // Count tallest candles
    for (int i = 0; i < n; i++) {
        if (candles[i] == max) {
            count++;
        }
    }

    return count;
}

int main() {
    int n;
    scanf("%d", &n);

    int candles[n];

    for (int i = 0; i < n; i++) {
        scanf("%d", &candles[i]);
    }

    printf("%d\n", birthdayCakeCandles(candles, n));

    return 0;
}
