#include <stdio.h>

void breakingRecords(int scores[], int n) {
    int maxScore = scores[0];
    int minScore = scores[0];
    int maxCount = 0;
    int minCount = 0;

    for (int i = 1; i < n; i++) {
        if (scores[i] > maxScore) {
            maxScore = scores[i];
            maxCount++;
        }
        else if (scores[i] < minScore) {
            minScore = scores[i];
            minCount++;
        }
    }

    printf("%d %d\n", maxCount, minCount);
}

int main() {
    int n;
    scanf("%d", &n);

    int scores[n];

    for (int i = 0; i < n; i++) {
        scanf("%d", &scores[i]);
    }

    breakingRecords(scores, n);

    return 0;
}
